{
  "functions": {
    "api/coingecko/[...path].js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/coingecko/:path*",
      "destination": "/api/coingecko/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
